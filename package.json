{
  "name": "@pavanbhatt/terminal-mcp",
  "version": "1.0.3",
  "description": "MCP server for remote terminal access via SSH",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "terminal-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "mcp",
